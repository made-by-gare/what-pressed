{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri_conf_schema.json",
  "productName": "WhatPressed",
  "identifier": "com.madebygare.what-pressed",
  "version": "0.2.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "What Pressed",
        "width": 1200,
        "height": 800,
        "minWidth": 860,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/made-by-gare/what-pressed/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDExMUM5NjgxMzEwMTBFOTgKUldTWURnRXhnWlljRVZhNDhTSWpSakN1eGNKWmgvSEVIcWY3WjN5ZUdZSXgwVlNXQVN2Tk82Z0IK"
    }
  }
}
